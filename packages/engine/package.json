{
  "name": "harness",
  "version": "0.1.0",
  "description": "Harness v1 engine — event log core, MCP server, CLI, hooks",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "harness": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepack": "node build.mjs && node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\"",
    "postpack": "node -e \"require('node:fs').rmSync('README.md', { force: true })\"",
    "typecheck": "tsc --noEmit -p ."
  },
  "devDependencies": {
    "@harness/schema": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "ulid": "^3.0.2"
  }
}
