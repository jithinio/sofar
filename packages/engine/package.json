{
  "name": "@alignlabs/sofar",
  "version": "0.8.1",
  "description": "Sofar v1 engine \u2014 event log core, MCP server, CLI, hooks",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "sofar": "dist/cli.js"
  },
  "exports": {
    "./schema": {
      "types": "./dist/types/engine/src/lib/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./engine": {
      "types": "./dist/types/engine/src/lib/engine.d.ts",
      "default": "./dist/engine.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepack": "node build.mjs && node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\"",
    "postpack": "node -e \"require('node:fs').rmSync('README.md', { force: true })\"",
    "typecheck": "tsc --noEmit -p ."
  },
  "devDependencies": {
    "@sofar/schema": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "ulid": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jithinio/sofar.git",
    "directory": "packages/engine"
  },
  "homepage": "https://sofar.sh",
  "bugs": {
    "url": "https://github.com/jithinio/sofar/issues"
  },
  "keywords": [
    "agents",
    "memory",
    "event-sourcing",
    "mcp",
    "claude-code",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
