{
  "name": "@sofar/schema",
  "version": "0.3.0",
  "description": "Sofar event payload schemas + validation — the swappable part, and the ONLY schema home",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./src/events.ts",
  "types": "./src/events.ts",
  "exports": {
    ".": {
      "types": "./src/events.ts",
      "default": "./src/events.ts"
    },
    "./tool-inputs": {
      "types": "./src/tool-inputs.ts",
      "default": "./src/tool-inputs.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ."
  }
}
